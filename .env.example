# ──────────────────────────────────────────────────────────────────────────
# FloraAI environment configuration.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# --- Agent: LLM provider (Anthropic / Claude) ---
# Get a key at https://console.anthropic.com/ . The agent uses Claude only for
# generation; embeddings run locally (sentence-transformers) to stay free.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cheapest capable model — keeps cost well under a $5 budget for development.
FLORA_AGENT_MODEL=claude-haiku-4-5

# Local embedding model (downloaded once from HuggingFace, then cached).
FLORA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Service URLs (used by the gateway to orchestrate the modules) ---
FLORA_ML_URL=http://localhost:8001
FLORA_DL_URL=http://localhost:8002
FLORA_AGENT_URL=http://localhost:8003

# --- Logging ---
FLORA_LOG_LEVEL=INFO
FLORA_ENV=development
